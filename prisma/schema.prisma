// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String
  status        WhitelistStatus @default(PENDING)
  role          Role            @default(USER)
  permissions   Permissions[]
  orderComments OrderComment[]
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([id, email], name: "user_id_email_idx")
  @@map("users")
}

model Customer {
  id                  String   @id @default(cuid())
  name                String
  email               String?  @unique
  phone               String
  whatsappPhoneNumber String?  @map("whatsapp_phone_number")
  street              String?  @map("address_street")
  city                String?  @map("address_city")
  state               String?  @map("address_state")
  postalCode          String?  @map("address_postal_code")
  orders              Order[]
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([id, email, phone], name: "customer_id_email_phone_idx")
  @@map("customers")
}

model Order {
  id            String         @id @default(cuid())
  items         OrderedItem[]
  status        OrderStatus    @default(NOT_STARTED) @map("status")
  paymentStatus PaymentStatus  @default(UNPAID) @map("payment_status")
  deliveryFee   Float?         @default(10.0) @map("delivery_fee")
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  customerId    String?        @map("customer_id")
  orderLogs     OrderLog[]
  orderComments OrderComment[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([id], name: "order_id_idx")
  @@map("orders")
}

model OrderLog {
  id        String   @id @default(cuid())
  message   String   @db.Text
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orderId   String   @map("order_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([id, orderId], name: "order_logs_id_order_id_idx")
  @@map("order_logs")
}

model OrderComment {
  id           String   @id @default(cuid())
  comment      String   @db.VarChar(500)
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orderId      String   @map("order_id")
  user         User?    @relation(fields: [userId], references: [id])
  userId       String?  @map("from_user_id")
  taggedUserId String?  @map("tagged_user_id")
  likedBy      String[] @map("liked_by")
  likedCount   Int      @default(0) @map("liked_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([id, orderId], name: "order_comments_id_order_id_idx")
  @@map("order_comments")
}

model OrderedItem {
  id        String   @id @default(cuid())
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  itemId    String   @map("item_id")
  quantity  Int      @default(1)
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  orderId   String?  @map("order_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([id, itemId, orderId], name: "ordered_item_id_order_id_idx")
  @@map("ordered_items")
}

model MenuItem {
  id          String        @id @default(cuid())
  title       String        @db.VarChar(300)
  slug        String        @unique
  description String?
  unitPrice   Float         @map("unit_price")
  orderItems  OrderedItem[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([id, slug], name: "menu_item_id_slug_idx")
  @@map("menu_items")
}

enum Role {
  USER
  SUPERUSER
  ADMIN
}

enum Permissions {
  READ_ORDERS
  READ_CUSTOMERS
  READ_USERS
  READ_MENU
  UPDATE_ORDERS
  UPDATE_CUSTOMERS
  UPDATE_USERS
  UPDATE_MENU
  DELETE_ORDERS
  DELETE_CUSTOMERS
  DELETE_USERS
  DELETE_MENU
}

enum OrderStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  VOIDED
}

enum WhitelistStatus {
  PENDING
  APPROVED
  REJECTED
}
